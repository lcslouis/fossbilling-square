        svCadenceChanged: function () {
            /* Map Square cadence → FOSSBilling period code → price column prefix */
            var cadenceToPeriod = {
                'DAILY': '1D', 'WEEKLY': '1W', 'EVERY_TWO_WEEKS': '2W',
                'MONTHLY': '1M', 'EVERY_TWO_MONTHS': '2M', 'QUARTERLY': '3M',
                'EVERY_FOUR_MONTHS': '4M', 'EVERY_SIX_MONTHS': '6M',
                'ANNUAL': '1Y', 'EVERY_TWO_YEARS': '2Y'
            };
            var periodToLabel = { '1D':'d','1W':'w','2W':'w','1M':'m','2M':'m','3M':'q','4M':'m','6M':'b','1Y':'a','2Y':'bia' };
            var cadence = document.getElementById('svCadence').value;
            var period  = cadenceToPeriod[cadence] || '';
            var pricesRaw = document.getElementById('svProductPrices').value;
            var hint = document.getElementById('sv-price-hint');
            try {
                var prices = JSON.parse(pricesRaw);
                if (Array.isArray(prices) && prices.length > 0 && period) {
                    var label = periodToLabel[period] || '';
                    var match = prices.find(function (pr) { return pr.period === label; });
                    if (match) {
                        document.getElementById('svAmount').value = match.price.toFixed(2);
                        hint.textContent = '✓ Auto-filled from product price';
                        hint.className = 'form-text text-success';
                        return;
                    }
                }
            } catch (e) {}
            hint.textContent = '';
        },

        createStaticVariation: async function () {
            var planId    = document.getElementById('svPlanId').value.trim();
            var productId = parseInt(document.getElementById('svProductId').value) || 0;
            var name      = document.getElementById('svName').value.trim();
            var cadence   = document.getElementById('svCadence').value;
            var amount    = parseFloat(document.getElementById('svAmount').value);
            var currency  = document.getElementById('svCurrency').value.trim() || 'USD';
            var autoMap   = document.getElementById('svAutoMap').checked;
            var resultEl  = document.getElementById('svResult');

            var cadenceToPeriod = {
                'DAILY':'1D','WEEKLY':'1W','EVERY_TWO_WEEKS':'2W','MONTHLY':'1M',
                'EVERY_TWO_MONTHS':'2M','QUARTERLY':'3M','EVERY_FOUR_MONTHS':'4M',
                'EVERY_SIX_MONTHS':'6M','ANNUAL':'1Y','EVERY_TWO_YEARS':'2Y'
            };

            resultEl.className = 'mt-2 alert alert-info';
            resultEl.innerHTML = 'Creating variation in Square…';
            resultEl.classList.remove('d-none');

            if (!planId) {
                resultEl.className = 'mt-2 alert alert-danger';
                resultEl.innerHTML = 'Please select a Square plan (Step 1).';
                return;
            }
            if (!(amount > 0)) {
                resultEl.className = 'mt-2 alert alert-danger';
                resultEl.innerHTML = 'Please enter a price greater than 0 (Step 3).';
                return;
            }

            try {
                var result = await api('create_static_variation', {
                    plan_id: planId, name: name, cadence: cadence,
                    amount: amount, currency: currency
                });

                var varId = result && result.variation_id ? result.variation_id : null;

                if (!varId) {
                    resultEl.className = 'mt-2 alert alert-warning';
                    resultEl.innerHTML = 'Variation created but ID not returned. Check Square dashboard.';
                    return;
                }

                var html = '✓ Variation created!<br>ID: <strong><code>' + varId + '</code></strong>';

                // Auto-create mapping if product selected and checkbox checked
                if (autoMap && productId > 0) {
                    var period = cadenceToPeriod[cadence] || cadence;
                    try {
                        await api('create_mapping', {
                            product_id:     productId,
                            billing_period: period,
                            sq_plan_id:     varId,
                            sq_plan_label:  name || cadence,
                            environment:    'sandbox'
                        });
                        html += '<br>✓ Plan mapping created: product ' + productId + ' → ' + period + ' → <code>' + varId + '</code>';
                        loadMappings();
                    } catch (mapErr) {
                        html += '<br>⚠ Mapping creation failed: ' + mapErr.message;
                    }
                } else if (autoMap && productId <= 0) {
                    html += '<br><span class="text-warning">No product selected — mapping not created. Add it manually using the variation ID above.</span>';
                }

                resultEl.className = 'mt-2 alert alert-success';
                resultEl.innerHTML = html;

                // Swap footer to Close + Create Another
                document.getElementById('sv-modal-footer').innerHTML =
                    '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>' +
                    '<button type="button" class="btn btn-outline-primary" onclick="SQM.svReset()">Create Another</button>';

            } catch (e) {
                resultEl.className = 'mt-2 alert alert-danger';
                resultEl.innerHTML = 'Error: ' + e.message;
            }
        },

        svReset: function () {
            // Reset all fields
            document.getElementById('svPlanId').value       = '';
            document.getElementById('svProductId').value    = '';
            document.getElementById('svProductPrices').value = '{}';
            document.getElementById('svName').value         = '';
            document.getElementById('svAmount').value       = '';
            document.getElementById('svCurrency').value     = 'USD';
            document.getElementById('sv-currency-label').textContent = 'USD';
            document.getElementById('svCadence').value      = 'MONTHLY';
            document.getElementById('svAutoMap').checked    = true;

            // Reset plan picker
            document.getElementById('sv-plan-selected-row').classList.add('d-none');
            document.getElementById('sv-plan-table').classList.add('d-none');
            document.getElementById('sv-plan-placeholder').classList.remove('d-none');
            document.getElementById('sv-plan-placeholder').textContent = 'Click "Load Plans" to browse your Square subscription plans.';

            // Reset product picker
            document.getElementById('sv-prod-selected-row').classList.add('d-none');
            document.getElementById('sv-prod-table').classList.add('d-none');
            document.getElementById('sv-prod-placeholder').classList.remove('d-none');
            document.getElementById('sv-prod-placeholder').textContent = 'Click "Load Products" to browse your FOSSBilling products.';

            // Reset result
            document.getElementById('svResult').className   = 'd-none';
            document.getElementById('svResult').innerHTML   = '';
            document.getElementById('sv-price-hint').textContent = '';

            // Restore original footer
            document.getElementById('sv-modal-footer').innerHTML =
                '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>' +
                '<button type="button" class="btn btn-primary" onclick="SQM.createStaticVariation()">Create Variation</button>';
        },

        /* Product picker */
        openProductPicker: function () {
            document.getElementById('product-picker-search').value = '';
            var pickerModal = bootstrap.Modal.getOrCreateInstance(
                document.getElementById('modalProductPicker'));
            pickerModal.show();
            /* Load once; cache for subsequent opens */
            if (_allProducts.length === 0) {
                loadProducts();
            } else {
                renderProductRows(_allProducts);
            }
        },

        selectProduct: function (id, name) {
            document.getElementById('mapping-product-id').value      = id;
            document.getElementById('mapping-product-display').value = name + ' (ID: ' + id + ')';
            bootstrap.Modal.getInstance(
                document.getElementById('modalProductPicker')).hide();
        },

        filterProducts: function (query) {
            if (!query) { renderProductRows(_allProducts); return; }
            var q = query.toLowerCase();
            renderProductRows(_allProducts.filter(function (p) {
                return String(p.id).includes(q) ||
                       (p.title || p.name || '').toLowerCase().includes(q);
            }));
        },

        /* Copy a Square Plan ID into the Add Mapping form and open it */
        useSquarePlanId: function (id) {
            var input = document.querySelector('#formAddMapping [name="sq_plan_id"]');
            if (input) {
                input.value = id;
                bootstrap.Modal.getOrCreateInstance(
                    document.getElementById('modalAddMapping')).show();
            }
        },

        deleteSquareObject: async function (objectId, objectName, objectType) {
            var label = objectType === 'plan' ? 'subscription plan' : 'variation';
            if (!confirm('Remove ' + label + ' "' + objectName + '" (' + objectId + ') from Square?\n\n' +
                'Plans will be fully deleted. Individual variations may be archived (hidden) instead if Square prevents direct deletion — the effect is the same for this integration.\n\n' +
                'Existing active subscriptions on this ' + label + ' will NOT be affected.')) {
                return;
            }
            try {
                var result = await api('delete_square_object', { object_id: objectId });
                var method = result && result.method === 'archived' ? 'archived' : 'deleted';
                // Remove the row from the table
                var row = document.getElementById('sq-obj-row-' + objectId);
                if (row) row.remove();
                // Reload the whole list if it was a plan (multiple rows affected)
                if (objectType === 'plan') {
                    loadSquareObjects();
                }
                alert('✓ ' + (method === 'archived' ? 'Archived (hidden from all locations).' : 'Deleted successfully.'));
            } catch (e) {
                alert('Failed: ' + e.message);
            }
        },

        /* Export mappings as CSV */
        exportMappingsCsv: function () {
            if (_mappingsCache.length === 0) {
                alert('No mappings loaded yet — wait for the table to finish loading.');
                return;
            }
            var rows = _mappingsCache.map(function (m) {
                return {
                    id:             m.id,
                    product_id:     m.product_id,
                    billing_period: m.billing_period,
                    sq_plan_id:     m.sq_plan_id,
                    sq_plan_label:  m.sq_plan_label || '',
                    environment:    m.environment,
                    notes:          m.notes || '',
                    created_at:     m.created_at || '',
                    updated_at:     m.updated_at || '',
                };
            });
            downloadCsv('square_mappings_' + today() + '.csv', rows);
        },

        /* Export subscriptions as CSV */
        exportSubscriptionsCsv: function () {
            if (_subscriptionsCache.length === 0) {
                alert('No subscriptions loaded yet — wait for the table to finish loading.');
                return;
            }
            var rows = _subscriptionsCache.map(function (s) {
                return {
                    id:                 s.id,
                    client_id:          s.client_id,
                    invoice_id:         s.invoice_id,
                    currency:           s.currency,
                    amount:             s.amount,
                    sq_subscription_id: s.sq_subscription_id,
                    sq_customer_id:     s.sq_customer_id  || '',
                    sq_card_id:         s.sq_card_id      || '',
                    status:             s.status,
                    created_at:         s.created_at      || '',
                    updated_at:         s.updated_at      || '',
                };
            });
            downloadCsv('square_subscriptions_' + today() + '.csv', rows);
        },

        /* Import mappings from pasted JSON array */
        importMappings: async function () {
            var raw    = document.getElementById('import-json-input').value.trim();
            var result = document.getElementById('import-result');
            result.className = 'mt-2';
            result.innerHTML = '';

            var mappings;
            try {
                mappings = JSON.parse(raw);
                if (!Array.isArray(mappings)) throw new Error('Input must be a JSON array.');
            } catch (e) {
                result.className += ' alert alert-danger';
                result.textContent = 'Invalid JSON: ' + e.message;
                return;
            }

            try {
                var res = await api('import_mappings', { mappings: mappings });
                result.className += ' alert alert-success';
                result.textContent =
                    'Import complete: ' + res.created + ' created, ' +
                    res.skipped + ' skipped (duplicates).';
                loadMappings();
                loadConfig();
            } catch (e) {
                result.className += ' alert alert-danger';
                result.textContent = 'Import failed: ' + e.message;
            }
        },

        deleteMapping: async function (id) {
            if (!confirm('Delete this mapping?')) return;
            try {
                await api('delete_mapping', { id: id });
                loadMappings();
                loadConfig();
            } catch (e) {
                alert('Delete failed: ' + e.message);
            }
        },

        filterSubscriptions: function () {
            var status = document.getElementById('sub-filter-status').value;
            loadSubscriptions(status || null);
        },

        cancelSub: async function (id) {
            if (!confirm('Cancel this subscription in Square? This will stop all future billing.')) return;
            try {
                await api('cancel_subscription', { id: id });
                loadSubscriptions();
            } catch (e) {
                alert('Cancellation failed: ' + e.message);
            }
        },

        syncSub: async function (id) {
            try {
                var res = await api('sync_subscription', { id: id });
                loadSubscriptions();
            } catch (e) {
                alert('Sync failed: ' + e.message);
            }
        },

        deleteSub: async function (id) {
            if (!confirm('Delete this subscription record from FOSSBilling?\n\nThis removes the local record only — the subscription in Square is not affected.')) return;
            try {
                await api('delete_subscription', { id: id });
                loadSubscriptions();
            } catch (e) {
                alert('Delete failed: ' + e.message);
            }
        },

        syncAllSubs: async function (btn) {
            if (!confirm('Pull current status from Square for all active subscriptions?')) return;
            var orig = btn.textContent;
            btn.disabled = true;
            btn.textContent = 'Syncing…';
            try {
                var res = await api('sync_all_subscriptions', {});
                loadSubscriptions();
                var msg = 'Sync complete.\nSynced: ' + res.synced;
                if (res.errors > 0) msg += '\nErrors: ' + res.errors;
                alert(msg);
            } catch (e) {
                alert('Sync all failed: ' + e.message);
            } finally {
                btn.disabled = false;
                btn.textContent = orig;
            }
        }
    };

    /* Boot */
    loadConfig();
    loadMappings();
    loadSubscriptions();

}());
</script>

{% endblock %}
