{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}

{% block meta_title %}{{ 'Square Manager'|trans }}{% endblock %}

{% set active_menu = 'system' %}

{% block breadcrumbs %}
<ol class="breadcrumb">
    <li class="breadcrumb-item">
        <a href="{{ '/'|url }}">
            <svg class="icon"><use xlink:href="#home" /></svg>
        </a>
    </li>
    <li class="breadcrumb-item">
        <a href="{{ 'system'|url }}">{{ 'Settings'|trans }}</a>
    </li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'Square Manager'|trans }}</li>
</ol>
{% endblock %}

{% block content %}



{# ── Config status banner ────────────────────────────────────────────────── #}
<div id="sq-config-banner" class="card mb-3">
    <div class="card-body text-muted">Checking configuration…</div>
</div>

{# ── Plan Mappings ───────────────────────────────────────────────────────── #}
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <h3 class="card-title mb-0">{{ 'Product → Square Plan Mappings'|trans }}</h3>
            <p class="card-subtitle mb-0">{{ 'Map FOSSBilling products to Square subscription plans.'|trans }}</p>
        </div>
        <div class="d-flex gap-2 flex-wrap justify-content-end">
            <button class="btn btn-sm btn-outline-secondary" onclick="SQM.loadSquareObjects()">
                {{ 'Browse Square Plans'|trans }}
            </button>
            <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#modalCreateVariation">
                ＋ {{ 'Create Static Variation'|trans }}
            </button>
            <button class="btn btn-sm btn-outline-secondary" onclick="SQM.exportMappingsCsv()">
                ⬇ {{ 'Export CSV'|trans }}
            </button>
            <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#modalImportMappings">
                ⬆ {{ 'Import JSON'|trans }}
            </button>
            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modalAddMapping">
                + {{ 'Add Mapping'|trans }}
            </button>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table card-table table-vcenter table-striped mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>{{ 'Product ID'|trans }}</th>
                    <th>{{ 'Billing Period'|trans }}</th>
                    <th>{{ 'Square Plan ID'|trans }}</th>
                    <th>{{ 'Label'|trans }}</th>
                    <th>{{ 'Environment'|trans }}</th>
                    <th>{{ 'Updated'|trans }}</th>
                    <th class="w-1"></th>
                </tr>
            </thead>
            <tbody id="tbl-mappings">
                <tr><td colspan="8" class="text-center text-muted py-3">Loading…</td></tr>
            </tbody>
        </table>
    </div>
</div>

{# ── Square Plans Browser (hidden until requested) ───────────────────────── #}
<div class="card mb-3 d-none" id="sq-objects-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">{{ 'Square Subscription Plans (read-only)'|trans }}</h3>
        <button class="btn btn-sm btn-outline-secondary"
                onclick="document.getElementById('sq-objects-card').classList.add('d-none')">
            {{ 'Hide'|trans }}
        </button>
    </div>
    <div class="table-responsive">
        <table class="table card-table table-sm mb-0">
            <thead>
                <tr>
                    <th>{{ 'Plan'|trans }}</th>
                    <th>{{ 'Variation'|trans }}</th>
                    <th>{{ 'Billing Cycle'|trans }}</th>
                    <th>{{ 'Variation ID (use this)'|trans }}</th>
                    <th class="w-1"></th>
                    <th class="w-1"></th>
                </tr>
            </thead>
            <tbody id="tbl-sq-objects">
                <tr><td colspan="6" class="text-muted text-center py-2">Loading…</td></tr>
            </tbody>
        </table>
    </div>
</div>

{# ── Subscriptions ───────────────────────────────────────────────────────── #}
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <h3 class="card-title mb-0">{{ 'Subscriptions'|trans }}</h3>
            <p class="card-subtitle mb-0">{{ 'Compare Square ↔ FOSSBilling subscription statuses.'|trans }}</p>
        </div>
        <div class="d-flex gap-2 flex-wrap justify-content-end">
            <div class="input-group input-group-sm" style="width:auto">
                <select id="sub-filter-status" class="form-select form-select-sm">
                    <option value="">{{ 'All statuses'|trans }}</option>
                    <option value="active">active</option>
                    <option value="canceled">canceled</option>
                    <option value="paused">paused</option>
                    <option value="pending">pending</option>
                </select>
                <button class="btn btn-outline-secondary btn-sm" onclick="SQM.filterSubscriptions()">
                    {{ 'Filter'|trans }}
                </button>
            </div>
            <button class="btn btn-sm btn-outline-info" onclick="SQM.syncAllSubs(this)">
                ↻ {{ 'Sync All from Square'|trans }}
            </button>
            <button class="btn btn-sm btn-outline-secondary" onclick="SQM.exportSubscriptionsCsv()">
                ⬇ {{ 'Export CSV'|trans }}
            </button>
        </div>
    </div>
    {# Mismatch legend #}
    <div class="px-3 pt-2 pb-1 small text-muted">
        <span class="badge bg-warning text-dark me-1">⚠ Mismatch</span> Square and FOSSBilling statuses differ — use <strong>Sync</strong> to pull the Square value, or <strong>Cancel</strong> to cancel in Square.
    </div>
    <div class="table-responsive">
        <table class="table card-table table-vcenter table-striped mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>{{ 'Client'|trans }}</th>
                    <th>{{ 'Invoice'|trans }}</th>
                    <th>{{ 'Amount'|trans }}</th>
                    <th>{{ 'Square Sub ID'|trans }}</th>
                    <th>{{ 'Square Status'|trans }}</th>
                    <th>{{ 'FOSS Status'|trans }}</th>
                    <th>{{ 'Match'|trans }}</th>
                    <th>{{ 'Created'|trans }}</th>
                    <th class="w-1"></th>
                </tr>
            </thead>
            <tbody id="tbl-subscriptions">
                <tr><td colspan="10" class="text-center text-muted py-3">Loading…</td></tr>
            </tbody>
        </table>
    </div>
</div>

{# ── Reference URLs ───────────────────────────────────────────────────────── #}
<div class="card mb-3">
    <div class="card-header">
        <h3 class="card-title mb-0">{{ 'Reference URLs'|trans }}</h3>
        <p class="card-subtitle mb-0">{{ 'Copy these into your Square Developer Dashboard.'|trans }}</p>
    </div>
    <div class="card-body">

        <label class="form-label fw-semibold">{{ 'Webhook URL'|trans }}</label>
        <p class="text-muted small mb-1">Paste into <strong>Square Developer Dashboard → Webhooks</strong>. Subscribe to: <code>subscription.updated</code>, <code>subscription.created</code></p>
        <div class="input-group mb-3">
            <input type="text" class="form-control font-monospace bg-light" id="webhookUrlDisplay" readonly
                   value="Loading…">
            <button class="btn btn-outline-secondary" type="button" id="btnCopyWebhook"
                    onclick="SQM.copyUrl('webhookUrlDisplay', 'btnCopyWebhook')">
                {{ 'Copy'|trans }}
            </button>
        </div>

        <label class="form-label fw-semibold">{{ 'IPN Callback URL'|trans }}</label>
        <p class="text-muted small mb-1">Shown here for reference. FOSSBilling uses this for payment confirmations.</p>
        <div class="input-group mb-0">
            <input type="text" class="form-control font-monospace bg-light" id="ipnUrlDisplay" readonly
                   value="Loading…">
            <button class="btn btn-outline-secondary" type="button" id="btnCopyIpn"
                    onclick="SQM.copyUrl('ipnUrlDisplay', 'btnCopyIpn')">
                {{ 'Copy'|trans }}
            </button>
        </div>

    </div>
</div>

{# ── Debug / Diagnostics ─────────────────────────────────────────────────── #}
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center"
         style="cursor:pointer" onclick="SQM.toggleDebug()">
        <h3 class="card-title mb-0">{{ 'Diagnostics &amp; Debug'|trans }}</h3>
        <span id="debug-toggle-icon">▼</span>
    </div>
    <div id="debug-panel" class="d-none">
        <div class="card-body border-bottom">
            <div class="row g-3">
                <div class="col-md-6">
                    <button class="btn btn-outline-primary w-100" onclick="SQM.runDiagnostics()">
                        {{ 'Run Configuration Check'|trans }}
                    </button>
                </div>
                <div class="col-md-6">
                    <button class="btn btn-outline-secondary w-100" onclick="SQM.testSquareApi()">
                        {{ 'Test Square API Connectivity'|trans }}
                    </button>
                </div>
            </div>
        </div>
        <div id="debug-output" class="card-body">
            <pre class="bg-dark text-light p-3 rounded mb-0"
                 style="min-height:80px;font-size:.8rem;white-space:pre-wrap">Click a button above to run diagnostics.</pre>
        </div>
    </div>
</div>

{# ── Add Mapping Modal ───────────────────────────────────────────────────── #}
<div class="modal fade" id="modalAddMapping" tabindex="-1">
    <div class="modal-dialog">
        <form id="formAddMapping" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ 'Add Plan Mapping'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                {# Product picker #}
                <div class="mb-3">
                    <label class="form-label required">{{ 'Product'|trans }}</label>
                    <input type="hidden" id="mapping-product-id" name="product_id" required>
                    <div class="input-group">
                        <input type="text" id="mapping-product-display" class="form-control"
                               placeholder="Click to choose a product…" readonly style="cursor:pointer"
                               onclick="SQM.openProductPicker()">
                        <button type="button" class="btn btn-outline-secondary" onclick="SQM.openProductPicker()">
                            {{ 'Browse'|trans }}
                        </button>
                    </div>
                </div>

                {# Billing period — must match FOSSBilling client_order.period values exactly #}
                <div class="mb-3">
                    <label class="form-label required">{{ 'Billing Period'|trans }}</label>
                    <select class="form-select" name="billing_period" required>
                        <option value="">— Select period —</option>
                        <optgroup label="Days / Weeks">
                            <option value="1D">Daily (1D)</option>
                            <option value="1W">Weekly (1W)</option>
                            <option value="2W">Every 2 Weeks (2W)</option>
                        </optgroup>
                        <optgroup label="Months">
                            <option value="1M">Monthly (1M)</option>
                            <option value="2M">Every 2 Months (2M)</option>
                            <option value="3M">Quarterly — 3 Months (3M)</option>
                            <option value="4M">Every 4 Months (4M)</option>
                            <option value="6M">Semi-Annual — 6 Months (6M)</option>
                        </optgroup>
                        <optgroup label="Years">
                            <option value="1Y">Annual — 1 Year (1Y)</option>
                            <option value="2Y">Every 2 Years (2Y)</option>
                        </optgroup>
                    </select>
                    <small class="form-hint">Must match the billing period set on the FOSSBilling product.</small>
                </div>

                {# Square plan ID #}
                <div class="mb-3">
                    <label class="form-label required">{{ 'Square Plan / Variation ID'|trans }}</label>
                    <input type="text" class="form-control" name="sq_plan_id" required
                           placeholder="e.g. PLAN_XXXXXXXXXXXXXXXXXXXX">
                </div>

                {# Label #}
                <div class="mb-3">
                    <label class="form-label">{{ 'Label'|trans }} <small class="text-muted">(optional)</small></label>
                    <input type="text" class="form-control" name="sq_plan_label">
                </div>

                {# Environment #}
                <div class="mb-3">
                    <label class="form-label">{{ 'Environment'|trans }}</label>
                    <select class="form-select" name="environment">
                        <option value="sandbox">Sandbox</option>
                        <option value="production">Production</option>
                    </select>
                </div>

                {# Notes #}
                <div class="mb-3">
                    <label class="form-label">{{ 'Notes'|trans }} <small class="text-muted">(optional)</small></label>
                    <textarea class="form-control" name="notes" rows="2"></textarea>
                </div>

                <div id="mapping-form-error" class="alert alert-danger d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                <button type="submit" class="btn btn-primary">{{ 'Save Mapping'|trans }}</button>
            </div>
        </form>
    </div>
</div>

{# ── Product Picker Modal ─────────────────────────────────────────────────── #}
<div class="modal fade" id="modalProductPicker" tabindex="-1" style="z-index:1060">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ 'Choose a Product'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-2">
                <div class="input-group mb-2">
                    <span class="input-group-text">
                        <svg class="icon"><use xlink:href="#search" /></svg>
                    </span>
                    <input type="text" id="product-picker-search" class="form-control"
                           placeholder="{{ 'Search by name or ID…'|trans }}"
                           oninput="SQM.filterProducts(this.value)">
                </div>
                <div class="table-responsive" style="max-height:420px;overflow-y:auto">
                    <table class="table table-sm table-hover card-table mb-0">
                        <thead class="sticky-top bg-white">
                            <tr>
                                <th style="width:60px">{{ 'ID'|trans }}</th>
                                <th>{{ 'Name'|trans }}</th>
                                <th>{{ 'Type'|trans }}</th>
                                <th>{{ 'Recurring Prices'|trans }}</th>
                                <th class="w-1"></th>
                            </tr>
                        </thead>
                        <tbody id="tbl-product-picker">
                            <tr><td colspan="5" class="text-center text-muted py-3">Loading products…</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
            </div>
        </div>
    </div>
</div>

{# ── Import Mappings Modal ────────────────────────────────────────────────── #}
<div class="modal fade" id="modalImportMappings" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ 'Import Plan Mappings (JSON)'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-2">
                    Paste the JSON array produced by "Export CSV → JSON" or copy from another environment.
                    Duplicates (same product/period/environment) are skipped automatically.
                </p>
                <textarea id="import-json-input" class="form-control font-monospace" rows="10"
                          placeholder='[{"product_id":1,"billing_period":"monthly","sq_plan_id":"PLAN_XXX","environment":"sandbox"}]'></textarea>
                <div id="import-result" class="mt-2 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                <button type="button" class="btn btn-primary" onclick="SQM.importMappings()">
                    {{ 'Import'|trans }}
                </button>
            </div>
        </div>
    </div>
</div>

{# ── Create Static Variation Modal ──────────────────────────────────────── #}
<div class="modal fade" id="modalCreateVariation" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ 'Create Static Pricing Variation'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3">Creates a <strong>STATIC (fixed price)</strong> variation on a Square subscription plan via the API — bypasses the Dashboard limitation that forces RELATIVE pricing. Also creates the FOSSBilling plan mapping automatically.</p>

                {# Step 1 — Select Square Plan #}
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                        <strong>Step 1 — Select Square Plan</strong>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="SQM.svLoadPlans()">Load Plans</button>
                    </div>
                    <div class="card-body p-0">
                        <div id="sv-plan-placeholder" class="text-muted text-center py-3 small">Click "Load Plans" to browse your Square subscription plans.</div>
                        <table class="table table-sm table-hover mb-0 d-none" id="sv-plan-table">
                            <thead><tr><th>Plan Name</th><th>Plan ID</th><th></th></tr></thead>
                            <tbody id="sv-plan-tbody"></tbody>
                        </table>
                        <div class="p-2 border-top d-none" id="sv-plan-selected-row">
                            <span class="text-success">✓ Selected: </span>
                            <strong id="sv-plan-selected-name"></strong>
                            <code class="ms-2 small" id="sv-plan-selected-id"></code>
                            <button type="button" class="btn btn-xs btn-outline-secondary ms-2" onclick="SQM.svClearPlan()">Change</button>
                        </div>
                    </div>
                </div>
                <input type="hidden" id="svPlanId">

                {# Step 2 — Select FOSSBilling Product #}
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                        <strong>Step 2 — Select FOSSBilling Product</strong>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="SQM.svLoadProducts()">Load Products</button>
                    </div>
                    <div class="card-body p-0">
                        <div id="sv-prod-placeholder" class="text-muted text-center py-3 small">Click "Load Products" to browse your FOSSBilling products.</div>
                        <table class="table table-sm table-hover mb-0 d-none" id="sv-prod-table">
                            <thead><tr><th>ID</th><th>Product</th><th>Prices</th><th></th></tr></thead>
                            <tbody id="sv-prod-tbody"></tbody>
                        </table>
                        <div class="p-2 border-top d-none" id="sv-prod-selected-row">
                            <span class="text-success">✓ Selected: </span>
                            <strong id="sv-prod-selected-name"></strong>
                            <button type="button" class="btn btn-xs btn-outline-secondary ms-2" onclick="SQM.svClearProduct()">Change</button>
                        </div>
                    </div>
                </div>
                <input type="hidden" id="svProductId">
                <input type="hidden" id="svProductPrices" value="{}">

                {# Step 3 — Variation Details #}
                <div class="card mb-3">
                    <div class="card-header py-2"><strong>Step 3 — Variation Details</strong></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Variation Name <span class="text-muted small">(optional — auto-generated if blank)</span></label>
                            <input type="text" class="form-control" id="svName" placeholder="e.g. Monthly Fixed">
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-5">
                                <label class="form-label">Cadence <span class="text-danger">*</span></label>
                                <select class="form-select" id="svCadence" onchange="SQM.svCadenceChanged()">
                                    <option value="DAILY"            data-period="1D">Daily (1D)</option>
                                    <option value="WEEKLY"           data-period="1W">Weekly (1W)</option>
                                    <option value="EVERY_TWO_WEEKS"  data-period="2W">Every 2 Weeks (2W)</option>
                                    <option value="MONTHLY" selected data-period="1M">Monthly (1M)</option>
                                    <option value="EVERY_TWO_MONTHS" data-period="2M">Every 2 Months (2M)</option>
                                    <option value="QUARTERLY"        data-period="3M">Quarterly (3M)</option>
                                    <option value="EVERY_FOUR_MONTHS" data-period="4M">Every 4 Months (4M)</option>
                                    <option value="EVERY_SIX_MONTHS" data-period="6M">Every 6 Months (6M)</option>
                                    <option value="ANNUAL"           data-period="1Y">Annual (1Y)</option>
                                    <option value="EVERY_TWO_YEARS"  data-period="2Y">Every 2 Years (2Y)</option>
                                </select>
                            </div>
                            <div class="col-4">
                                <label class="form-label">Price <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text" id="sv-currency-label">USD</span>
                                    <input type="number" class="form-control" id="svAmount" placeholder="0.00" min="0.01" step="0.01">
                                </div>
                                <div class="form-text" id="sv-price-hint"></div>
                            </div>
                            <div class="col-3">
                                <label class="form-label">Currency</label>
                                <input type="text" class="form-control" id="svCurrency" value="USD" maxlength="3"
                                       oninput="document.getElementById('sv-currency-label').textContent=this.value||'USD'">
                            </div>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="svAutoMap" checked>
                            <label class="form-check-label" for="svAutoMap">
                                Automatically create plan mapping after variation is created
                            </label>
                        </div>
                    </div>
                </div>

                <div id="svResult" class="d-none mt-2"></div>
            </div>
            <div class="modal-footer" id="sv-modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                <button type="button" class="btn btn-primary" id="sv-create-btn" onclick="SQM.createStaticVariation()">{{ 'Create Variation'|trans }}</button>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    'use strict';

    /* Cached data for CSV export */
    var _mappingsCache      = [];
    var _subscriptionsCache = [];

    /* API helper — wraps FOSSBilling.api.admin.post() (callback-based)
       into a Promise so async/await works throughout.
       FOSSBilling handles CSRF automatically via the csrf_token cookie. */
    function api(method, payload) {
        return new Promise(function (resolve, reject) {
            FOSSBilling.api.admin.post(
                'squaremanager/' + method,
                payload || {},
                function (result) { resolve(result); },
                function (error)  { reject(new Error((error && error.message) || 'API error')); }
            );
        });
    }

    /* Raw FOSSBilling API helper — any module path, not just squaremanager */
    function apiRaw(path, payload) {
        return new Promise(function (resolve, reject) {
            FOSSBilling.api.admin.post(
                path,
                payload || {},
                function (result) { resolve(result); },
                function (error)  { reject(new Error((error && error.message) || 'API error')); }
            );
        });
    }

    /* Product picker state */
    var _allProducts = [];

    async function loadProducts() {
        var tbody = document.getElementById('tbl-product-picker');
        tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-2">Loading...</td></tr>';
        try {
            /* Use our own get_products endpoint which JOINs product_payment for real prices */
            var list = await api('get_products');
            _allProducts = Array.isArray(list) ? list : [];
            renderProductRows(_allProducts);
        } catch (e) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-danger py-2">Failed to load products: ' + e.message + '</td></tr>';
        }
    }

    function renderProductRows(products) {
        var tbody = document.getElementById('tbl-product-picker');
        if (!products || products.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No products found.</td></tr>';
            return;
        }
        tbody.innerHTML = products.map(function (p) {
            /* Build a compact price summary from recurring periods, e.g. "Mo:$9.99 Yr:$99.00" */
            var priceParts = [];
            if (Array.isArray(p.prices) && p.prices.length > 0) {
                p.prices.forEach(function (pr) {
                    priceParts.push(pr.label + ': $' + pr.price.toFixed(2));
                });
            } else if (p.once_price != null && p.once_price > 0) {
                priceParts.push('Once: $' + parseFloat(p.once_price).toFixed(2));
            } else if (p.payment_type === 'free') {
                priceParts.push('Free');
            }
            var priceHtml = priceParts.length
                ? '<small>' + priceParts.join(' &nbsp; ') + '</small>'
                : '<span class="text-muted">-</span>';

            var titleEsc = (p.title || 'Product ' + p.id)
                            .replace(/\\/g, '\\\\')
                            .replace(/'/g, "\\'");
            return '<tr style="cursor:pointer" onclick="SQM.selectProduct(' + p.id + ',\'' + titleEsc + '\')">' +
                '<td><code>' + p.id + '</code></td>' +
                '<td>' + (p.title || '') + '</td>' +
                '<td><span class="badge bg-secondary">' + (p.type || '-') + '</span></td>' +
                '<td>' + priceHtml + '</td>' +
                '<td><button type="button" class="btn btn-sm btn-primary">Select</button></td>' +
                '</tr>';
        }).join('');
    }

    /* CSV download helper */
    function downloadCsv(filename, rows) {
        if (!rows || rows.length === 0) { alert('No data to export.'); return; }
        var headers = Object.keys(rows[0]);
        var lines   = [headers.join(',')].concat(rows.map(function (r) {
            return headers.map(function (h) {
                var v = r[h] == null ? '' : String(r[h]);
                return '"' + v.replace(/"/g, '""') + '"';
            }).join(',');
        }));
        var blob = new Blob([lines.join('\r\n')], { type: 'text/csv' });
        var a    = document.createElement('a');
        a.href   = URL.createObjectURL(blob);
        a.download = filename;
        a.click();
        URL.revokeObjectURL(a.href);
    }

