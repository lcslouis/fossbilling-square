    /* Subscriptions comparison table */
    var _subFilterStatus = null;
    async function loadSubscriptions(filterStatus) {
        if (filterStatus !== undefined) _subFilterStatus = filterStatus || null;
        var tbody = document.getElementById('tbl-subscriptions');
        try {
            var rows = await api('list_subscriptions_sync', {});
            _subscriptionsCache = rows || [];

            /* Client-side status filter */
            if (_subFilterStatus) {
                rows = rows.filter(function (s) {
                    return s.sq_status === _subFilterStatus || s.foss_status === _subFilterStatus;
                });
            }

            if (!rows || rows.length === 0) {
                tbody.innerHTML =
                    '<tr><td colspan="10" class="text-center text-muted py-3">No subscription records.</td></tr>';
                return;
            }

            function stBadge(status) {
                if (!status) return '<span class="text-muted">—</span>';
                var cls = status === 'active'   ? 'success'
                        : status === 'canceled' ? 'secondary'
                        : status === 'paused'   ? 'info'
                        : 'warning';
                return '<span class="badge bg-' + cls + '">' + status + '</span>';
            }

            tbody.innerHTML = rows.map(function (s) {
                var rowClass = s.status_mismatch ? 'table-warning' : '';
                var matchCell = s.foss_status === null
                    ? '<span class="text-muted small">no FOSS record</span>'
                    : s.status_mismatch
                        ? '<span class="badge bg-warning text-dark">⚠ Mismatch</span>'
                        : '<span class="badge bg-success">✓</span>';

                var clientLabel = s.client_name
                    ? s.client_name + ' <small class="text-muted">(#' + s.client_id + ')</small>'
                    : '#' + s.client_id;

                var actions = '';
                if (s.sq_status === 'active') {
                    actions += '<button class="btn btn-sm btn-outline-danger me-1" ' +
                               'onclick="SQM.cancelSub(' + s.id + ')" title="Cancel in Square">Cancel</button>';
                }
                actions += '<button class="btn btn-sm btn-outline-info me-1" ' +
                           'onclick="SQM.syncSub(' + s.id + ')" title="Pull status from Square">Sync</button>';
                if (s.sq_status !== 'active') {
                    actions += '<button class="btn btn-sm btn-outline-secondary" ' +
                               'onclick="SQM.deleteSub(' + s.id + ')" title="Delete local record">Delete</button>';
                }

                return '<tr class="' + rowClass + '">' +
                    '<td>' + s.id + '</td>' +
                    '<td>' + clientLabel + '</td>' +
                    '<td><a href="/admin/invoice/manage/' + s.invoice_id + '">#' + s.invoice_id + '</a></td>' +
                    '<td>' + s.currency + ' ' + parseFloat(s.amount).toFixed(2) + '</td>' +
                    '<td><code style="font-size:.72rem">' + s.sq_subscription_id + '</code></td>' +
                    '<td>' + stBadge(s.sq_status) + '</td>' +
                    '<td>' + stBadge(s.foss_status) + '</td>' +
                    '<td>' + matchCell + '</td>' +
                    '<td>' + (s.created_at || '').substring(0, 10) + '</td>' +
                    '<td class="text-nowrap">' + actions + '</td>' +
                    '</tr>';
            }).join('');
        } catch (e) {
            tbody.innerHTML =
                '<tr><td colspan="10" class="text-danger py-2">Error loading subscriptions: ' + e.message + '</td></tr>';
        }
    }

    /* Square catalog objects browser */
    async function loadSquareObjects() {
        var card  = document.getElementById('sq-objects-card');
        var tbody = document.getElementById('tbl-sq-objects');
        card.classList.remove('d-none');
        tbody.innerHTML =
            '<tr><td colspan="4" class="text-muted text-center py-2">Fetching from Square…</td></tr>';
        try {
            var objects = await api('list_square_objects');
            if (!objects || objects.length === 0) {
                tbody.innerHTML =
                    '<tr><td colspan="6" class="text-muted text-center py-2">' +
                    'No active subscription plans found in Square.</td></tr>';
                return;
            }
            /* Each variation gets its own row; plan name shown on first variation only */
            var rows = [];
            objects.forEach(function (o) {
                var planIdEsc = o.id.replace(/'/g, "\\'");
                var planNameEsc = (o.name || o.id).replace(/'/g, "\\'");
                var vars = o.variations || [];
                vars.forEach(function (v, i) {
                    var planCell = i === 0
                        ? '<strong>' + o.name + '</strong>'
                        : '<span class="text-muted ps-2">↳</span>';
                    var varIdEsc   = v.id.replace(/'/g, "\\'");
                    var varNameEsc = (v.name || v.id).replace(/'/g, "\\'");
                    rows.push(
                        '<tr id="sq-obj-row-' + v.id + '">' +
                        '<td>' + planCell + '</td>' +
                        '<td>' + (v.name || '—') + '</td>' +
                        '<td>' + (v.cadence || '—') + '</td>' +
                        '<td><code class="small">' + v.id + '</code></td>' +
                        '<td>' +
                            '<button class="btn btn-xs btn-outline-secondary" ' +
                                'title="Use this variation ID in Add Mapping form" ' +
                                'onclick="SQM.useSquarePlanId(\'' + varIdEsc + '\')">Use</button>' +
                        '</td>' +
                        '<td>' +
                            '<button class="btn btn-xs btn-outline-danger" ' +
                                'title="Delete this variation from Square catalog" ' +
                                'onclick="SQM.deleteSquareObject(\'' + varIdEsc + '\',\'' + varNameEsc + '\',\'variation\')">Delete</button>' +
                        '</td>' +
                        '</tr>'
                    );
                });
                // Delete plan button on the plan's first row
                if (vars.length > 0) {
                    rows.push(
                        '<tr>' +
                        '<td colspan="4" class="text-end text-muted small pe-2">Delete entire plan:</td>' +
                        '<td></td>' +
                        '<td>' +
                            '<button class="btn btn-xs btn-danger" ' +
                                'title="Delete this subscription plan from Square catalog" ' +
                                'onclick="SQM.deleteSquareObject(\'' + planIdEsc + '\',\'' + planNameEsc + '\',\'plan\')">Delete Plan</button>' +
                        '</td>' +
                        '</tr>'
                    );
                }
            });
            tbody.innerHTML = rows.join('');
        } catch (e) {
            tbody.innerHTML =
                '<tr><td colspan="4" class="text-danger py-2">Error: ' + e.message + '</td></tr>';
        }
    }

