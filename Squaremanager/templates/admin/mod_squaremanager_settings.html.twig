    /* Config status banner + populate IPN URL */
    async function loadConfig() {
        var banner = document.getElementById('sq-config-banner');
        try {
            var cfg = await api('validate_config');
            if (cfg && cfg.valid) {
                banner.innerHTML =
                    '<div class="card-body alert alert-success mb-0">' +
                    '&#10003; ' + cfg.summary +
                    ' &nbsp; Environment: <strong>' + cfg.environment + '</strong>' +
                    ' &nbsp; Mappings: <strong>' + cfg.mapping_count + '</strong></div>';
            } else {
                var issues = ((cfg && cfg.issues) || ['Unknown configuration error'])
                    .map(function (i) { return '<li>' + i + '</li>'; }).join('');
                banner.innerHTML =
                    '<div class="card-body alert alert-warning mb-0">' +
                    '<strong>Configuration issues:</strong><ul class="mb-0">' + issues + '</ul></div>';
            }
            /* Populate reference URL fields */
            var base = window.location.protocol + '//' + window.location.host;

            var webhookField = document.getElementById('webhookUrlDisplay');
            if (webhookField) {
                webhookField.value = base + '/api/guest/squaremanager/handle_webhook';
            }

            var ipnField = document.getElementById('ipnUrlDisplay');
            if (ipnField) {
                ipnField.value = base + '/ipn.php' +
                                 (cfg && cfg.gateway_id ? '?gateway_id=' + cfg.gateway_id : '');
            }
        } catch (e) {
            banner.innerHTML =
                '<div class="card-body alert alert-danger mb-0">Could not load config status: ' + e.message + '</div>';
        }
    }

