{% extends "layout_default.html.twig" %}
{% set active_menu = 'extensions' %}

{% block meta_title %}Square Manager{% endblock %}

{% block content %}

<div class="card">
    <div class="card-body">

        <h3>Square Manager</h3>
        <p>Manage recurring subscription mappings and inspect Square objects.</p>


<div style="margin-bottom: 15px; display:flex; gap:10px; flex-wrap:wrap;">
    <button id="sync-all" class="btn btn-primary">Auto Sync All</button>
    <button id="view-square-objects" class="btn btn-secondary">View Square Objects</button>



    <a href="/index.php?_url=/admin/squaremanager/export" class="btn btn-success">
        Export Items CSV
    </a>


</div>


        <!-- ✅ DEBUG PANEL -->
        <div class="card mb-3">
            <div class="card-header">
                Debug Panel
            </div>
            <div class="card-body">
                <button id="toggle-debug" class="btn btn-sm btn-warning">Toggle Debug</button>
                <div id="debug-output" style="margin-top:10px; white-space:pre-wrap; font-family:monospace;"></div>
            </div>
        </div>

        <!-- ✅ MAIN TABLE -->
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Billing</th>
                    <th>SKU</th>
                    <th>Plan Variation ID</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="mapping-table"></tbody>
        </table>

        <!-- ✅ INSPECTOR -->
        <div id="square-objects-panel" class="mt-4" style="display:none;">
            <h4>Square Item Variations</h4>
            <table class="table table-bordered table-sm">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Variation</th>
                        <th>SKU</th>
                        <th>ID</th>
                    </tr>
                </thead>
                <tbody id="item-variation-table"></tbody>
            </table>

            <h4 class="mt-4">Subscription Plan Variations</h4>
            <table class="table table-bordered table-sm">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>ID</th>
                        <th>Plan</th>
                        <th>Cadence</th>
                    </tr>
                </thead>
                <tbody id="plan-variation-table"></tbody>
            </table>
        </div>

    </div>
</div>

{% endblock %}


{% block js %}

<script>
document.addEventListener("DOMContentLoaded", function () {

    const table = document.getElementById("mapping-table");
    const panel = document.getElementById("square-objects-panel");
    const itemTable = document.getElementById("item-variation-table");
    const planTable = document.getElementById("plan-variation-table");
    const debugBox = document.getElementById("debug-output");

    let DEBUG = false;

    function debugLog(msg) {
        if (!DEBUG) return;

        console.log('[SquareManager DEBUG]', msg);

        if (typeof msg === 'object') {
            debugBox.textContent += JSON.stringify(msg, null, 2) + "\n";
        } else {
            debugBox.textContent += msg + "\n";
        }
    }

    document.getElementById("toggle-debug").onclick = function () {
        DEBUG = !DEBUG;
        debugLog("DEBUG ENABLED");
        alert("Debug " + (DEBUG ? "ON" : "OFF"));
    };


function apiCall(endpoint, data = {}) {
    debugLog("API CALL → " + endpoint);
    debugLog(data);

    const formData = new FormData();

    for (const key in data) {
        formData.append(key, data[key]);
    }

    // ✅ ADD THIS LINE (CRITICAL FIX)
    formData.append('CSRFToken', '{{ CSRFToken }}');

    return fetch('/api/admin/squaremanager/' + endpoint, {
        method: 'POST',
        body: formData,
        credentials: 'same-origin'
    })
    .then(async res => {
        const json = await res.json();

        debugLog("API RESPONSE ← " + endpoint);
        debugLog(json);

        if (!res.ok || json.error) {
            throw json;
        }

        return json.result;
    })
    .catch(err => {
        debugLog("❌ API ERROR:");
        debugLog(err);
        alert(err?.error?.message || 'API error');
    });
}


    function loadMappings() {
        debugLog("Loading mappings...");

        apiCall('mapping').then(rows => {
            table.innerHTML = '';

            if (!rows) return;

            rows.forEach(row => {
                const tr = document.createElement('tr');

                tr.innerHTML = `
                    <td>${row.product}</td>
                    <td>${row.billing}</td>
                    <td>${row.sku}</td>
                    <td>
                        <input value="${row.variation || ''}" class="form-control variation-input">
                    </td>
                    <td>
                        <button class="btn btn-success btn-sm save-btn">Save</button>
                        <button class="btn btn-secondary btn-sm detect-btn">Detect</button>
                    </td>
                `;

                tr.querySelector('.save-btn').onclick = () => {
                    const input = tr.querySelector('.variation-input');

                    apiCall('save_mapping', {
                        product_id: row.product_id,
                        billing: row.billing,
                        sku: row.sku,
                        variation: input.value
                    }).then(() => {
                        alert("Saved");
                    });
                };

                tr.querySelector('.detect-btn').onclick = () => {
                    apiCall('auto_sync', {
                        single: true,
                        sku: row.sku
                    }).then(r => {
                        if (r && r.length > 0) {
                            tr.querySelector('.variation-input').value = r[0].variation;
                        } else {
                            alert("Not found");
                        }
                    });
                };

                table.appendChild(tr);
            });
        });
    }

    document.getElementById("sync-all").onclick = function () {
        apiCall('auto_sync').then(() => {
            alert("Auto sync complete");
            loadMappings();
        });
    };

    document.getElementById("view-square-objects").onclick = function () {
        debugLog("Fetching Square objects...");

        apiCall('list_square_objects').then(result => {
            panel.style.display = 'block';
            itemTable.innerHTML = '';
            planTable.innerHTML = '';

            if (!result) return;

            (result.item_variations || []).forEach(x => {
                itemTable.innerHTML += `
                    <tr>
                        <td>${x.item_name}</td>
                        <td>${x.variation_name}</td>
                        <td>${x.sku}</td>
                        <td>${x.id}</td>
                    </tr>
                `;
            });

            (result.plan_variations || []).forEach(x => {
                planTable.innerHTML += `
                    <tr>
                        <td>${x.name}</td>
                        <td>${x.id}</td>
                        <td>${x.plan_id}</td>
                        <td>${x.cadence}</td>
                    </tr>
                `;
            });
        });
    };

    loadMappings();

});
</script>

{% endblock %}