{% extends "layout_default.html.twig" %}
<h1>Square Manager Loaded ?</h1>
{# -------------------------------------------------- #}
{# Page Metadata                                       #}
{# -------------------------------------------------- #}
{% block meta_title %}Square Manager{% endblock %}

{% block content %}

<div class="card">
    <div class="card-header">
        <h3>Square Manager </h3>
    </div>

    <div class="card-body">

        {# -------------------------------------------------- #}
        {# Top Controls Section                               #}
        {# -------------------------------------------------- #}
        {# Provides actions for:
           - Exporting products to Square format
           - Running automatic SKU/variation sync
           - Filtering and searching mappings
           - Enabling debug mode
        #}

        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">

            {# Export button
               Downloads CSV compatible with Square import
            #}
            <a href="/admin/squaremanager/export" class="btn btn-success">
                Export Products
            </a>

            {# Auto sync button
               Attempts to auto-detect variation IDs from Square using SKU logic
            #}
            <button id="sync-btn" class="btn btn-warning">
                Auto Sync All
            </button>

            {# Toggle filter to show only missing (unmapped) rows #}
            <button id="filter-btn" class="btn btn-secondary">
                Show Only Missing
            </button>

            {# Search box for filtering by product name or SKU #}
            <input id="search-box"
                   type="text"
                   placeholder="Search products or SKU..."
                   style="padding:6px; width:250px;">

            {# Debug mode toggle
               Shows additional internal data for troubleshooting
            #}
            <label style="margin-left:10px;">
                <input type="checkbox" id="debug-toggle">
                Debug
            </label>

            {# Status message area (sync results, errors, etc.) #}
            <span id="sync-status" style="margin-left:10px;"></span>
        </div>

        {# -------------------------------------------------- #}
        {# Summary Metrics                                    #}
        {# -------------------------------------------------- #}
        {# Displays number of rows missing variation mappings #}

        <div style="margin-top:10px;">
            Missing: <b id="missing-count">0</b>
        </div>

        <hr>

        {# -------------------------------------------------- #}
        {# Mapping Table                                      #}
        {# -------------------------------------------------- #}
        {# Displays:
           - Product name
           - Billing period
           - Generated SKU
           - Stored variation ID
           - Status indicator
           - Actions (Save / Detect)
        #}

        <table class="table table-striped table-hover">
            <thead style="position:sticky; top:0; background:#fff;">
                <tr>
                    <th>Product</th>
                    <th>Billing</th>
                    <th>SKU</th>
                    <th>Variation ID</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="mapping-table"></tbody>
        </table>

    </div>
</div>

{# -------------------------------------------------- #}
{# Frontend Logic                                      #}
{# -------------------------------------------------- #}
<script>
(async function() {

    const table = document.getElementById('mapping-table');
    const syncBtn = document.getElementById('sync-btn');
    const filterBtn = document.getElementById('filter-btn');
    const searchBox = document.getElementById('search-box');
    const debugToggle = document.getElementById('debug-toggle');
    const missingCountEl = document.getElementById('missing-count');
    const status = document.getElementById('sync-status');

    let showMissingOnly = false;
    let rowsCache = [];

    /**
     * Determine display status for a mapping row
     */
    function getStatus(variation) {
        if (variation && variation.length > 0) {
            return { text: 'Mapped', color: 'green' };
        }
        return { text: 'Missing', color: 'red' };
    }

    /**
     * Render the mapping table
     *
     * Applies:
     * - search filtering
     * - missing-only filter
     * - visual indicators
     */
    function render(rows) {
        table.innerHTML = '';

        let missingCount = 0;

        rows.forEach(row => {

            // Search filter
            const search = searchBox.value.toLowerCase();
            if (
                search &&
                !row.product.toLowerCase().includes(search) &&
                !row.sku.toLowerCase().includes(search)
            ) {
                return;
            }

            // Missing-only filter
            if (showMissingOnly && row.variation) {
                return;
            }

            const statusObj = getStatus(row.variation);

            if (!row.variation) missingCount++;

            const tr = document.createElement('tr');

            // Highlight missing rows
            tr.style.background = row.variation ? '' : '#fff3f3';

            tr.innerHTML = `
                <td>${row.product}</td>
                <td><b>${row.billing}</b></td>
                <td>${row.sku}</td>

                <td>
                    <input type="text"
                        value="${row.variation || ''}"
                        data-product="${row.product_id}"
                        data-billing="${row.billing}"
                        data-sku="${row.sku}"
                        style="width:280px;">
                </td>

                <td style="color:${statusObj.color};">
                    ${statusObj.text}
                </td>

                <td>
                    <button class="btn btn-sm btn-primary save-btn">Save</button>
                    <button class="btn btn-sm btn-info detect-btn">Detect</button>
                </td>
            `;

            const saveBtn = tr.querySelector('.save-btn');
            const detectBtn = tr.querySelector('.detect-btn');
            const input = tr.querySelector('input');

            /**
             * Save mapping manually
             */
            saveBtn.onclick = async () => {

                saveBtn.innerText = 'Saving...';

                try {
                    await API.admin.squaremanager_save_mapping({
                        product_id: input.dataset.product,
                        billing: input.dataset.billing,
                        sku: input.dataset.sku,
                        variation: input.value
                    });

                    saveBtn.innerText = '✅';
                } catch {
                    saveBtn.innerText = '❌';
                }

                setTimeout(() => saveBtn.innerText = 'Save', 1500);
            };

            /**
             * Per-row auto-detect
             *
             * Attempts to resolve variation ID for a single SKU
             */
            detectBtn.onclick = async () => {

                detectBtn.innerText = '...';

                try {
                    const result = await API.admin.squaremanager_auto_sync({
                        sku: input.dataset.sku,
                        single: true
                    });

                    if (result.length && result[0].variation) {
                        input.value = result[0].variation;
                    }

                    detectBtn.innerText = '✅';
                } catch {
                    detectBtn.innerText = '❌';
                }

                setTimeout(() => detectBtn.innerText = 'Detect', 1500);
            };

            table.appendChild(tr);

            /**
             * Debug output row
             */
            if (debugToggle.checked) {
                const debugRow = document.createElement('tr');
                debugRow.innerHTML = `
                    <td colspan="6" style="background:#eee; font-size:12px;">
                        Product ID: ${row.product_id}<br>
                        SKU: ${row.sku}
                    </td>
                `;
                table.appendChild(debugRow);
            }
        });

        missingCountEl.innerText = missingCount;
    }

    /**
     * Load mapping data from API
     */
    async function load() {
        rowsCache = await API.admin.squaremanager_mapping();
        render(rowsCache);
    }

    await load();

    /**
     * Toggle missing filter
     */
    filterBtn.onclick = () => {
        showMissingOnly = !showMissingOnly;
        filterBtn.innerText = showMissingOnly ? 'Show All' : 'Show Only Missing';
        render(rowsCache);
    };

    /**
     * Search input handler
     */
    searchBox.oninput = () => render(rowsCache);

    /**
     * Auto sync all mappings
     */
    syncBtn.onclick = async () => {

        syncBtn.innerText = 'Syncing...';
        status.innerText = '';

        try {
            const result = await API.admin.squaremanager_auto_sync({});
            status.innerText = `✅ Synced ${result.length} items`;

            await load();
        } catch {
            status.innerText = '❌ Sync failed';
        }

        syncBtn.innerText = 'Auto Sync All';
    };

})();
</script>

{% endblock %}